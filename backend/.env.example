PORT=8787
BILLING_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Backend runtime uses only privileged Supabase key.
# Do not use publishable/anon keys here.
LV_STORAGE_PROVIDER=auto
DEEPL_API_KEY=
DEEPL_API_BASE_URL=https://api-free.deepl.com
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
LV_PROVIDER_MODE_A_ORDER=deepl,google
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LV_MODE_B_PROVIDER_ORDER=openai,groq
LV_MODE_B_ENGINE=custom
LV_PDF_ENGINE_PYTHON=python
LV_MODE_B_ENGINE_TIMEOUT_MS=600000
LV_BABELDOC_WATERMARK_MODE=no_watermark
LV_BABELDOC_PRIMARY_FONT_FAMILY=sans-serif
LV_BABELDOC_DISABLE_RICH_TEXT_TRANSLATE=0
LV_BABELDOC_SPLIT_SHORT_LINES=0
LV_BABELDOC_SHORT_LINE_SPLIT_FACTOR=0.8
LV_BABELDOC_DISABLE_CONTENT_FILTER_HINT=1
LV_BABELDOC_CA_BUNDLE=
LV_BABELDOC_INSECURE_TLS=0
LV_BABELDOC_ALLOW_SOURCE_FALLBACK_ON_REPETITION=0
OUTPUT_CACHE_MAX=200
OUTPUT_CACHE_PERSIST=1
LV_RATE_LIMIT_SHARED=1
LV_ENABLE_METRICS=1
LV_METRICS_ALLOW_PRIMARY_KEY=1
LV_METRICS_API_KEY=

# Security hardening
LV_API_KEY=change-me
# or comma-separated keys: keyA,keyB
LV_MAX_UPLOAD_BYTES=15728640
LV_RATE_LIMIT_CREATE_PER_MIN=10
LV_RATE_LIMIT_RUN_PER_MIN=30
LV_RATE_LIMIT_GET_PER_MIN=120
